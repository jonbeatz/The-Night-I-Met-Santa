{
  "mcpServers": {
    "affinity": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp-proxy",
        "mcp-proxy",
        "--transport",
        "sse",
        "http://127.0.0.1:6767/sse"
      ]
    },
    "indesign-uxp": {
      "command": "node",
      "args": [
        "D:\\Hermes\\projects\\The-Night-I-Met-Santa\\tools\\layout-mcp\\indesign-uxp-server\\src\\index.js"
      ],
      "cwd": "D:\\Hermes\\projects\\The-Night-I-Met-Santa\\tools\\layout-mcp\\indesign-uxp-server",
      "env": {
        "INDESIGN_BRIDGE_HTTP_PORT": "19300",
        "INDESIGN_BRIDGE_WS_PORT": "19301"
      }
    },
    "indesign-exec": {
      "command": "D:\\Hermes\\projects\\The-Night-I-Met-Santa\\tools\\layout-mcp\\indesign-scripting-mcp\\.venv\\Scripts\\python.exe",
      "args": [
        "D:\\Hermes\\projects\\The-Night-I-Met-Santa\\tools\\layout-mcp\\indesign-scripting-mcp\\exec_server.py"
      ],
      "cwd": "D:\\Hermes\\projects\\The-Night-I-Met-Santa\\tools\\layout-mcp\\indesign-scripting-mcp"
    },
    "photoshop": {
      "transport": "http",
      "url": "http://127.0.0.1:8766/mcp",
      "name": "Photoshop (adobepy UXP)"
    }
  }
}